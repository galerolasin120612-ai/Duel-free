                    local riseSpeed = math.random(3, 7) / 1000
                    local sway = math.random(-3, 3) / 100
                    local swaySpeed = math.random(2, 6) / 1000
                    while particle and particle.Parent and windowObj.EmbersEnabled do
                        local currentPos = particle.Position
                        local time = tick()
                        local swayOffset = math.sin(time * swaySpeed) * sway
                        particle.Position = UDim2.new(currentPos.X.Scale + swayOffset, currentPos.X.Offset, currentPos.Y.Scale - riseSpeed, currentPos.Y.Offset)
                        if particle.Position.Y.Scale < -0.1 then particle:Destroy() break end
