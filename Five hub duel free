    local function findNearestPlayerHRP()
        local myChar = LocalPlayer.Character
        if not myChar then return nil, nil end
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil, nil end
        local nearestHRP, nearestPlayer, nearestDist = nil, nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (myHRP.Position - hrp.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearestHRP = hrp
                        nearestPlayer = p
                    end
                end
            end
        end
        return nearestHRP, nearestPlayer
    end
    local function isCarryingBrainrot()
        local char = LocalPlayer.Character; if not char then return false end
        for _, v in ipairs(char:GetDescendants()) do
            local n = (v.Name or ""):lower()
            if (n:find("brain") or n:find("rot") or n:find("brainrot")) then
                if v:IsA("Model") or v:IsA("BasePart") then return true end
            end
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, c in ipairs(hrp:GetChildren()) do
                if c:IsA("WeldConstraint") or c:IsA("Motor6D") then
                    local combo = (((c.Part0 and c.Part0.Name) or "") .. " " .. ((c.Part1 and c.Part1.Name) or "")):lower()
                    if combo:find("brain") or combo:find("rot") then return true end
                end
            end
        end
        return false
