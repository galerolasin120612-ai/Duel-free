    local function startUpDownFloat()
        if CONFIG.UP_DOWN_FLOAT then return end
        CONFIG.UP_DOWN_FLOAT = true
        startFL_AntiRag()
        startFL_AntiKb()
        if upDownFloatConn then upDownFloatConn:Disconnect() end
        
        upDownFloatConn = RunService.Heartbeat:Connect(function()
            if not CONFIG.UP_DOWN_FLOAT then return end
            local hrp = getHRP()
            local hum = getHumanoid()
            if not hrp or not hum then return end
            
            hum:ChangeState(Enum.HumanoidStateType.Freefall)
            
            if tick() >= upDownNextSwitch then
                if upDownTargetOffset > 8 then
                    upDownTargetOffset = math.random(60, 75) / 10 -- Goes to 6.0 - 7.5
                else
                    upDownTargetOffset = math.random(90, 105) / 10 -- Goes to 9.0 - 10.5
                end
                upDownNextSwitch = tick() + (math.random(8, 15) / 10)
                upDownSpeed = math.random(15, 25)
            end
            
            local floorY = hrp.Position.Y - upDownTargetOffset
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {LocalPlayer.Character}
            params.FilterType = Enum.RaycastFilterType.Exclude
            local ray = workspace:Raycast(hrp.Position, Vector3.new(0, -50, 0), params)
