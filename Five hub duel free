            local PinBtn = Instance.new("TextButton", Container)
            PinBtn.Size = UDim2.new(0, 20, 0, 20); PinBtn.Position = UDim2.new(1, -25, 0.5, -10)
            PinBtn.BackgroundTransparency = 1; PinBtn.Text = "â˜†"; PinBtn.TextSize = 16
            PinBtn.TextColor3 = Color3.fromRGB(100, 100, 100)
          
            Btn.MouseButton1Click:Connect(function() if opts.Callback then opts.Callback() end end)
            
            local isPinned = false
            local PinnedObj = nil
            
            local function UpdatePin(state)
                if isPinned == state then return end
                isPinned = state
                if isPinned then
                    PinBtn.Text = "â˜…"; PinBtn.TextColor3 = BrightRed
                    PinnedObj = Instance.new("Frame", Window.PinnedContainer)
                    PinnedObj.Size = UDim2.new(1, -8, 0, 24); PinnedObj.BackgroundColor3 = DarkBackground
                    Instance.new("UICorner", PinnedObj).CornerRadius = UDim.new(0, 4)
                    Instance.new("UIStroke", PinnedObj).Color = RimRed
                    local mB = Instance.new("TextButton", PinnedObj)
                    mB.Size = UDim2.new(1, 0, 1, 0); mB.BackgroundTransparency = 1
                    mB.Text = text; mB.TextColor3 = Color3.new(1,1,1); mB.Font = Enum.Font.GothamBold; mB.TextSize = 10
                    mB.MouseButton1Click:Connect(function() if opts.Callback then opts.Callback() end end)
                else
                    PinBtn.Text = "â˜†"; PinBtn.TextColor3 = Color3.fromRGB(100, 100, 100)
                    if PinnedObj then PinnedObj:Destroy(); PinnedObj = nil end
                end
            end
            
            PinBtn.MouseButton1Click:Connect(function() UpdatePin(not isPinned) end)
            
            if opts.Pinned then UpdatePin(true) end
          
            local obj = { 
                SetPinned = UpdatePin,
                GetPinned = function() return isPinned end,
                Container = Container 
            }
            table.insert(AllUIObjects, obj)
            return obj
        end
        function Window:BalanceUI()
            local count = #AllUIObjects
            local mid = math.floor(count / 2)
            local isOdd = (count % 2 ~= 0)
            for i, obj in ipairs(AllUIObjects) do
                obj.Container.Size = UDim2.new(1, 0, 0, obj.Container.Size.Y.Offset)
                if i <= mid then
                    obj.Container.Parent = LeftCol
                elseif isOdd and i == count then
                    obj.Container.Parent = CenterCol
                    obj.Container.Size = UDim2.new(0.6, 0, 0, obj.Container.Size.Y.Offset)
                else
                    obj.Container.Parent = RightCol
                end
            end
        end
        return Window
    end
    
