    local function StartEmberEffect(container, windowObj)
        task.spawn(function()
            while windowObj.EmbersEnabled do
                task.wait(math.random(10, 20) / 100)
                local particle = Instance.new("Frame")
                local size = math.random(2, 4)
                particle.Size = UDim2.new(0, size, 0, size)
                particle.Position = UDim2.new(math.random(-10, 110)/100, 0, 1.1, 0)
